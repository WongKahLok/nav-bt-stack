<?xml version="1.0"?>
<!--
  Phase 1 initial tree  (BehaviorTree.CPP v3 format)

  The whole job of this file is to prove the loop works end-to-end:
  XML  ->  factory maps "NavToPose" to your C++ class  ->  executor ticks it
  ->  Nav2 drives the base to each pose.

  Start with ONE NavToPose if you want the absolute minimum, then add the
  second to see a Sequence run them in order (each must SUCCEED before the
  next starts). Coordinates are in the `map` frame -- set them to real,
  reachable points on your map.

  v3 note: the root tag uses `main_tree_to_execute`. (v4 uses BTCPP_format="4"
  instead -- don't mix them.)
-->
<root main_tree_to_execute="MainTree">

  <BehaviorTree ID="MainTree">
    <Sequence name="patrol">
      <NavToPose x="1.0"  y="0.0"  yaw="0.0"   frame_id="map"/>
      <NavToPose x="2.5"  y="1.0"  yaw="1.57"  frame_id="map"/>
    </Sequence>
  </BehaviorTree>

</root>